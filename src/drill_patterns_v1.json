  "patterns": {
    "BLOQUE_1": {
      "description": "Verbos -AR singulares (yo, tú, él/ella)",
      "blocks": [
        {
          "title": "1. VERBO {main_verb}",
          "accent": "granate",
          "template": {
            "yo": { "es": "{conjugated_yo} {obj}", "en": "I {verb_en} {obj_en}" },
            "tú": { "es": "{conjugated_tu} {obj}", "en": "You {verb_en} {obj_en}" },
            "él": { "es": "{conjugated_él} {obj}", "en": "He {verb_en} {obj_en}" }
          },
          "slots": {
            "obj": { "role": "OBJETO_POSEIBLE", "article": "definite" }
          }
        },
        {
          "title": "2. NEGACIÓN",
          "accent": "carbon",
          "template": {
            "yo": { "es": "No {conjugated_yo} {obj}", "en": "I don't {verb_en} {obj_en}" },
            "tú": { "es": "No {conjugated_tu} {obj}", "en": "You don't {verb_en} {obj_en}" },
            "él": { "es": "No {conjugated_él} {obj}", "en": "He doesn't {verb_en} {obj_en}" }
          },
          "slots": {
            "obj": { "role": "OBJETO_POSEIBLE", "article": "definite" }
          }
        },
        {
          "title": "3. PRONOMBRE LO / LA",
          "accent": "mostaza",
          "template": {
            "masc": { "es": "Lo {conjugated_yo}.", "en": "I {verb_en} it (masc)." },
            "fem": { "es": "La {conjugated_yo}.", "en": "I {verb_en} it (fem)." }
          },
          "slots": {}
        }
      ]
    }
  }
